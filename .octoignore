# .octoignore — patterns of files and directories to exclude from tracking
# Syntax: gitignore-compatible patterns (*, ?, **, etc.)
# Examples:
#   node_modules/       — ignore all node_modules directories
#   *.log               — ignore all .log files
#   build/              — ignore the build directory
#   .env                — ignore .env file
#   __pycache__/        — ignore Python cache directories
#   .git/               — ignore .git directories
pythonPrototype/build/ 
pythonPrototype/__pycache__/ 
pythonPrototype/venv/
pythonPrototype/dist/
.zig-cache/
.claude/


